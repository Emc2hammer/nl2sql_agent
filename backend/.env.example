# SiliconFlow API (兼容 OpenAI 接口)
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Main LLM: Qwen3-Coder-30B-A3B-Instruct
LLM_MODEL_NAME=Qwen/Qwen3-Coder-30B-A3B-Instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60

# Embedding: BAAI/bge-m3 (via SiliconFlow Embedding API)
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# Reranker: BAAI/bge-reranker-v2-m3 (via SiliconFlow Rerank API)
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# Supervisor / Reflection LLM: Aliyun Bailian OpenAI-compatible API
SCOPEDASHBOARD_API_KEY=
SCOPEDASHBOARD_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SCOPEDASHBOARD_MODEL=qwen3.5-35b-a3b
SCOPEDASHBOARD_TEMPERATURE=0
SCOPEDASHBOARD_REQUEST_TIMEOUT=30

# Few-shot Example Store
EXAMPLE_STORE_PATH=data/knowledge/few_shots.json
EXAMPLE_RETRIEVAL_TOP_K=3
ENABLE_TEMPLATE_REUSE=false
TEMPLATE_REUSE_THRESHOLD=0.95

# Database Configuration (SQLite for MVP, file stored in backend/data/)
DATABASE_URL=sqlite:///./data/nl2sql.db

# App Configuration
APP_PORT=8001
APP_HOST=0.0.0.0
DEBUG=false
TRACE_LEVEL=normal

# Allowed Tables (comma-separated, empty = all tables allowed)
ALLOWED_TABLES=

# Query Timeout in seconds
QUERY_TIMEOUT=30
